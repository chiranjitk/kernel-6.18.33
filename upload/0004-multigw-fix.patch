--- a/net/netfilter/nf_nat_core.c	2020-10-09 01:29:40.464916555 +0530
+++ b/net/netfilter/nf_nat_core.c	2020-10-09 01:43:45.607307447 +0530
@@ -24,6 +24,7 @@
 #include <net/netfilter/nf_nat.h>
 #include <net/netfilter/nf_nat_helper.h>
 #include <uapi/linux/netfilter/nf_nat.h>
+#include <linux/inetdevice.h>
 
 #include "nf_internals.h"
 
@@ -1158,6 +1159,8 @@ unsigned int ip_nat_route_input(void *pr
 	enum ip_conntrack_dir dir;
 	unsigned long statusbit;
 	__be32 saddr;
+	struct net_device *device;
+	struct net *net;
 
 	if (!(conn = nf_ct_get(skb, &ctinfo)))
 		return NF_ACCEPT;
@@ -1168,25 +1171,41 @@ unsigned int ip_nat_route_input(void *pr
 	statusbit = IPS_SRC_NAT;
 	if (dir == IP_CT_DIR_REPLY)
 		statusbit ^= IPS_NAT_MASK;
-	if (!(conn->status & statusbit))
-		return NF_ACCEPT;
-
-	if (skb_dst(skb))
-		return NF_ACCEPT;
 
-	if (skb->len < sizeof(struct iphdr))
+	if (!(conn->status & IPS_NAT_MASK)) {
+		if(!(conn->multi_gw_ifindex)) 
+			return NF_ACCEPT;
+
+		net = dev_net(skb->dev);
+		device = dev_get_by_index(net, conn->multi_gw_ifindex);
+
+		if (device != NULL) {
+			__be32 out_addr = inet_select_addr(device, 0, RT_SCOPE_LINK);
+			iph = ip_hdr(skb);
+			dev_put(device);
+			if (ip_route_input_lookup(skb, iph->daddr, iph->saddr, iph->tos, skb->dev, out_addr))
+				return NF_DROP;
+		}
+	}
+	
+	if (!(conn->status & statusbit)) {
 		return NF_ACCEPT;
+	} else {
+		if (skb_dst(skb))
+			return NF_ACCEPT;
 
-	/* use daddr in other direction as masquerade address (lsrc) */
-	iph = ip_hdr(skb);
-	saddr = conn->tuplehash[!dir].tuple.dst.u3.ip;
-	if (saddr == iph->saddr)
-		return NF_ACCEPT;
+		if (skb->len < sizeof(struct iphdr))
+			return NF_ACCEPT;
 
-	if (ip_route_input_lookup(skb, iph->daddr, iph->saddr, iph->tos,
-	    skb->dev, saddr))
-		return NF_DROP;
+		/* use daddr in other direction as masquerade address (lsrc) */
+		iph = ip_hdr(skb);
+		saddr = conn->tuplehash[!dir].tuple.dst.u3.ip;
+		if (saddr == iph->saddr)
+			return NF_ACCEPT;
 
+		if (ip_route_input_lookup(skb, iph->daddr, iph->saddr, iph->tos, skb->dev, saddr))
+			return NF_DROP;
+	}
 	return NF_ACCEPT;
 }
 EXPORT_SYMBOL_GPL(ip_nat_route_input);
